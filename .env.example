# Sphere Connect wallet URL.
NEXT_PUBLIC_UNIVOUCHER_WALLET_URL=https://sphere.unicity.network

# Merchant recipient must be resolvable by Sphere, e.g. @yourmerchant.
NEXT_PUBLIC_UNIVOUCHER_MERCHANT_NAMETAG=@merchant

# REQUIRED: canonical lowercase 64-hex coin id for Connect intent send.
# Do not put UCT here. Connect send expects coinId, not symbol.
NEXT_PUBLIC_UNIVOUCHER_PAYMENT_COIN_ID=

# Display only. Payment amount still uses product.priceBaseUnits.
NEXT_PUBLIC_UNIVOUCHER_PAYMENT_SYMBOL=UCT

# UCT on testnet2 has 18 decimals. USDU/USDC on testnet2 have 6 decimals.
NEXT_PUBLIC_UNIVOUCHER_PAYMENT_DECIMALS=18
